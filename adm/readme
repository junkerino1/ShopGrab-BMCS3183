━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
  ENVIRONMENT SETUP
━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

Before running the scripts, ensure that you are in the correct directory where the SQL files are located. 
The scripts are designed to be run in a specific order due to dependencies between tables, triggers, and procedures.
Recommended method: right click and open terminal in the folder containing these SQL files, 
then connect to SQL*Plus and run the scripts sequentially.

Run the following in SQL*Plus to create the test user with DBA privileges.

    DROP USER shopgrab CASCADE;
    CREATE USER shopgrab IDENTIFIED BY 12345678;
    GRANT DBA TO shopgrab;
    GRANT CREATE SESSION TO shopgrab;

Connect using:
    Username : shopgrab
    Password : 12345678

Then configure output and load scripts in strict dependency order:

    SET SERVEROUTPUT ON
    SET LINESIZE 120
    SET PAGESIZE 100
    SET DEFINE OFF

    @create_table.sql
    @setup.sql
    @lv0_table.sql
    @lv1_table.sql
    @lv2_table.sql
    @lv3_table.sql
    @lv4_table.sql

    run complete_order_simulation.sql to mark all orders as completed and free up riders for testing.
    @complete_order_simulation.sql


━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
  STEP 1 — REGISTER A NEW CUSTOMER
  Procedure: prc_register_customer
━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

Appends a new row to the CUSTOMER table.

  Trigger fired: trg_after_customer_insert
    → Auto-creates an empty COIN_WALLET
    → Auto-creates a default 'Silver' C_LOYALTY profile
    → Calls prc_init_customer_defaults for default settings

    EXEC prc_register_customer('shereen@email.com', 'shereen', '6969', '0112223344', 'A3809 PV18, KL');

  Verify — customer row created:
    SELECT customer_id, username, email FROM CUSTOMER WHERE username = 'shereen';

  Verify — wallet and loyalty tier auto-created by trigger:
    SELECT cl.customer_id, lt.tier_name, cl.total_spent
    FROM C_LOYALTY cl JOIN LOYALTY_TIER lt ON lt.tier_id = cl.tier_id
    WHERE cl.customer_id = (SELECT customer_id FROM CUSTOMER WHERE username = 'shereen');


━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
  STEP 2 — LOGIN & SESSION CHECK
  Procedure: prc_login_customer | Package: App_Session
━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

Validates credentials and stores login state in the App_Session package.
Use App_Session.get_customer_id throughout the rest of this demo.

    EXEC prc_login_customer('shereen', '6969');

  Verify — session is live:
    SELECT App_Session.get_customer_id AS session_cust_id,
           App_Session.get_username   AS session_user
    FROM DUAL;


━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
  STEP 3 — CLAIM A VOUCHER
  Procedure: prc_claim_voucher
━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

Assigns a public voucher to the user's wallet.

  Trigger fired: trg_before_vwallet_insert
    → Blocks expired, inactive, or exhausted vouchers before insert

    EXEC prc_claim_voucher(App_Session.get_customer_id, 'NEWUSER10');

  Verify — voucher stored in wallet:
    SELECT * FROM VOUCHER_WALLET WHERE customer_id = App_Session.get_customer_id;

  Guard — duplicate claim (throws Application Error):
    EXEC prc_claim_voucher(App_Session.get_customer_id, 'NEWUSER10');

  Guard — non-existent voucher code:
    EXEC prc_claim_voucher(App_Session.get_customer_id, 'FAKEDISCOUNT99');


━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
  STEP 4 — SUBSCRIBE TO PREMIUM
  Procedure: prc_add_subscription
━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

Creates a SUBSCRIPTION row and chains to payment logic.
Running it again stacks an additional +30 days on top of the current end date.

  Trigger fired: trg_after_sub_payment_insert
    → Activates subscription seamlessly

  Check state before subscribing:
    SELECT subscription_id, plan_id, status, start_date, end_date
    FROM SUBSCRIPTION WHERE customer_id = App_Session.get_customer_id;

  First subscription:
    EXEC prc_add_subscription(App_Session.get_customer_id);

  Stack another +30 days:
    EXEC prc_add_subscription(App_Session.get_customer_id);

  Verify — date stacking:
    SELECT subscription_id, plan_id, status, start_date, end_date
    FROM SUBSCRIPTION WHERE customer_id = App_Session.get_customer_id;


━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
  STEP 5 — BUILD A CART
  Procedure: prc_add_to_cart | prc_view_cart
━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

Inserts items into the TEMP_CART global temporary table.

  Trigger fired: trg_before_cart_insert
    → Enforces single-restaurant rule — mixing restaurants is blocked

  Add items from Burger King (restaurant_id = 1):
    EXEC prc_add_to_cart(1, 1, 2);
    EXEC prc_add_to_cart(4, 1, 1);
    EXEC prc_add_to_cart(5, 1, 2);

  Guard — mixing restaurants triggers a block (restaurant_id = 2):
    EXEC prc_add_to_cart(6, 2, 1);

  View cart:
    EXEC prc_view_cart;


━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
  STEP 6 — CHECKOUT (FULL TRIGGER CHAIN DEMO)
  Procedure: prc_checkout
━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

Orchestrates discount application, payment creation, and receipt generation.
Because the customer is subscribed (Step 4), delivery is free via prc_apply_discounts.

  Triggers fired:
    → trg_after_cust_order_insert  : Assigns rider, increments RIDER.ongoing_delivery
    → trg_after_payment_insert     : Awards coins, empties TEMP_CART, marks voucher used
    → trg_before_cloyalty_upd      : Checks total_spent and upgrades loyalty tier if eligible
    → trg_after_voucher_update     : Decrements public VOUCHER.usage_limit

  Check state before checkout:
    SELECT total_coins FROM COIN_WALLET WHERE customer_id = App_Session.get_customer_id;
    SELECT voucher_id, is_used FROM VOUCHER_WALLET WHERE customer_id = App_Session.get_customer_id;
    SELECT usage_limit, status FROM VOUCHER WHERE voucher_id = 1;
    SELECT cl.total_spent, lt.tier_name FROM C_LOYALTY cl
    JOIN LOYALTY_TIER lt ON cl.tier_id = lt.tier_id
    WHERE cl.customer_id = App_Session.get_customer_id;

  Execute checkout (Delivery, E-Wallet, voucher 1, 0 coins redeemed):
    EXEC prc_checkout('D', 'E-Wallet', 'A3809 PV18, KL', 1, 0);

  Verify after checkout:

    Coins awarded (trg_after_payment_insert):
      SELECT total_coins FROM COIN_WALLET WHERE customer_id = App_Session.get_customer_id;

    Loyalty tier updated (trg_before_cloyalty_upd):
      SELECT cl.total_spent, lt.tier_name FROM C_LOYALTY cl
      JOIN LOYALTY_TIER lt ON cl.tier_id = lt.tier_id
      WHERE cl.customer_id = App_Session.get_customer_id;

    Voucher marked as used:
      SELECT voucher_id, is_used FROM VOUCHER_WALLET WHERE customer_id = App_Session.get_customer_id;

    Public voucher usage_limit decremented (trg_after_voucher_update):
      SELECT usage_limit, status FROM VOUCHER WHERE voucher_id = 1;

    Rider assigned (trg_after_cust_order_insert):
      SELECT order_id, rider_id, order_status
      FROM CUST_ORDER WHERE customer_id = App_Session.get_customer_id;

    Please remember this order_id

      SELECT rider_id, ongoing_delivery, status FROM RIDER WHERE rider_id = (
          SELECT rider_id FROM CUST_ORDER
          WHERE customer_id = App_Session.get_customer_id
      );


━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
  STEP 7 — COMPLETE THE DELIVERY
  Procedure: prc_complete_delivery
━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

Closes the order cycle — flips order status to Completed and frees the rider.

  Trigger fired: trg_before_rider_update
    → Decrements ongoing_delivery by 1
    → If ongoing_delivery drops below 5, reverts rider status from 'Busy' to 'Available'

    EXEC prc_complete_delivery(insert your order_id);

  Verify — order status:
    SELECT order_id, order_status FROM CUST_ORDER WHERE order_id = [insert your order_id];

  Verify — rider workload decremented:
    SELECT rider_id, name, ongoing_delivery, status FROM RIDER WHERE rider_id = 21;


━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
  STEP 8 — ADD A NEW RIDER
  Procedure: prc_add_rider
━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

Inserts a new rider and auto-syncs the platform's rider count.

  Trigger fired: trg_after_rider_insert
    → Increments PLATFORM.rider_count

  Platform count before (Platform 1 = GrabFood):
    SELECT platform_id, platform_name, rider_count FROM PLATFORM WHERE platform_id = 1;

  Add the rider:
    EXEC prc_add_rider('Bob The Builder', '880101-14-1234', '0129999999', 1, 'WWW8888');

  Platform count after:
    SELECT platform_id, platform_name, rider_count FROM PLATFORM WHERE platform_id = 1;

  New rider row:
    SELECT rider_id, name, status, ongoing_delivery FROM RIDER WHERE identification_no = '880101-14-1234';


━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
  STEP 9 — ANALYTICAL REPORTS
━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

  A. Average Order Value
       EXEC prc_average_order_value_report;
       EXEC prc_average_order_value_report(4);        -- specific month

  B. Coin Transaction History
       EXEC prc_coin_transaction_history(App_Session.get_customer_id);

  C. Customer Retention (inactivity risk)
       EXEC prc_customer_retention_report;

  D. Monthly Restaurant Sales
       EXEC prc_monthly_restaurant_sales;

  E. Rider Delivery Report
       EXEC prc_rider_delivery_report(4);             -- month required

  F. Subscription Countdown
       EXEC prc_sub_countdown_report;

  G. Voucher Redemption
       EXEC prc_voucher_redemption_report;
       EXEC prc_voucher_redemption_report(1);         -- specific voucher

  H. Top 10 Most Ordered Menu Items
       EXEC prc_top_menu_item_report;
       EXEC prc_top_menu_item_report(4);              -- specific month

  I. Top 10 Customer Spending
       EXEC prc_top_cus_spending_report;
       EXEC prc_top_cus_spending_report(4);           -- specific month

  J. Platform Report (rolling last 90 days)
       EXEC prc_platform_report;

