-- To set up your testing environment, run the following commands in SQL*Plus. 
-- This will create a new user 'shopgrab' with DBA privileges, allowing you 
-- to execute the comprehensive test script without permission issues.
DROP USER shopgrab CASCADE;
CREATE USER shopgrab IDENTIFIED BY Junk#0512;
GRANT DBA TO shopgrab;
GRANT CREATE SESSION TO shopgrab;

============================================================
  COMPREHENSIVE TEST SCRIPT & DEMO — Food Delivery System
  Optimized for SQL*Plus v11.2
